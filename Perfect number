a=int(input("enter the number of which you want to check perfect sum of: "))
b=0
if a>0:
    for i in range(1,a-1):
        if a%i==0:
            b+=i
    if b==a:
        print(f"{a} is perfect")
    else:
        print(f"{a} is not perfect")
elif a==0:
    print("0 is not perfect")
else:
    print("negative integers can't be perfect")