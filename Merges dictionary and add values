a=int(input("enter the number of entries you want in first dictionary: "))
b={}
for i in range(a):
    c=input("enter key: ")
    d=int(input("enter value: "))
    b[c]=d
e=int(input("enter the number of entries you want in second dictionary: "))
f={}
for i in range(e):
    g=input("enter key: ")
    h=int(input("enter value: "))
    f[g]=h
for i in f:
    if i in b.keys():
        b[i]+=f[i]
    else:
        b[i]=f[i]
print(b)